### 1. LOGIN AS ADMIN
# This request will automatically save the token to the 'adminToken' variable
POST http://localhost:5000/api/auth/login
Content-Type: application/json

{
  "email": "test@placeholder.com",
  "password": "01123581321test"
}


### 2. LOGIN AS STUDENT
# This request will automatically save the token to the 'studentToken' variable
POST http://localhost:5000/api/auth/login
Content-Type: application/json

{
  "email": "student@example.com",
  "password": "1234567890test"
}


