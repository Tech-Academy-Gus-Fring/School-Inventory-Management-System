# API Configuration
# Preferred API base used by frontend service client
VITE_API_BASE_URL=/api
# Optional legacy proxy target for Vite dev server
VITE_API_URL=http://127.0.0.1:5000
VITE_API_TIMEOUT=30000

# OAuth Configuration
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback/google

VITE_APPLE_CLIENT_ID=your-apple-client-id
VITE_APPLE_REDIRECT_URI=http://localhost:5173/auth/callback/apple

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_QR_SCANNER=true

# Environment
VITE_DEBUG_MODE=false
